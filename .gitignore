# Standard python ignores
*.egg-info
.coverage
.ipynb_checkpoints
**/__pycache__/
.python-version
*.pyc
**/build

# Ignore these macos generated files
.DS_Store

# Ignore these Windows generated files
*Zone.Identifier

# Ignore VS Code generated files
*.vscode

# Raw data
raw_data/
*.csv
*.sqlite
*.zip

# Data in the package
# Python code in data/ is tracked; only raw data files are ignored (*.csv, *.sqlite above)

# Saved models
models/
*.joblib
*.h5

# Any pickle files
*.pickle
*.pckl
*.pkl

# Credentials (or files with potentially credentials inside)
.env
.env.yaml
.credentials
secrets.toml
*.json

diagnose_nans.py
my_plot.png
plot_example.py
